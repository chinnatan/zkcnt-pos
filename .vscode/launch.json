    "version": "0.2.0",
    "configurations": [
        {
            "name": "zKCNT POS Web (main_local)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_local.dart",
            "args": ["-d", "chrome","--web-port", "8080", "--web-header=Cross-Origin-Opener-Policy=same-origin", "--web-header=Cross-Origin-Embedder-Policy=require-corp"],
        },
        {
            "name": "zKCNT POS Web (main_dev)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "args": ["-d", "chrome","--web-port", "8080"],
        },
        {
            "name": "zKCNT POS Web (main_prd)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_prd.dart",
            "args": ["-d", "chrome","--web-port", "8080"],
        },
        {
            "name": "zKCNT POS Mobile (main_local)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_mobile_local.dart",
            "args": [
                "--flavor",
                "local",
            ]
        },
        {
            "name": "zKCNT POS Mobile (main_dev)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_mobile_dev.dart",
            "args": [
                "--flavor",
                "develop",
            ]
        },
        {
            "name": "zKCNT POS Mobile (main_prd)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_mobile_prd.dart",
            "args": [
                "--flavor", "production",
            ]
        }
    ]
}