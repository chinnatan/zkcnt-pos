# PocketBase base URL — must be reachable from the user's browser (NOT a Docker hostname)
# Local dev:  http://localhost:8090
# Production: https://pos.zkcnt.com  (Nginx proxies /api/ to PocketBase)
POCKETBASE_URL=http://localhost:8090
# Nuxt reads this name directly; set on production (can match POCKETBASE_URL)
# NUXT_PUBLIC_POCKETBASE_URL=https://pos.zkcnt.com

# Production Nginx host port (Cloudflare tunnel should point here)
PORT=3000
