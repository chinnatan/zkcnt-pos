# ─── Development (task local / task dev) ───
# API URL must be reachable from the user's browser (NOT a Docker hostname)
API_URL=http://localhost:4001
NUXT_PUBLIC_API_URL=http://localhost:4001
NUXT_PUBLIC_APP_URL=http://localhost:4000
ALLOWED_ORIGIN=http://localhost:4000

# ─── Cloudflare Production ───
# Leave NUXT_PUBLIC_API_URL empty — browser uses window.location.origin + '/api'
# NUXT_PUBLIC_API_URL=
# NUXT_PUBLIC_UPLOADS_URL=
# NUXT_PUBLIC_APP_URL=https://pos.yourdomain.com
# APP_URL=https://pos.yourdomain.com
# ALLOWED_ORIGIN=https://pos.yourdomain.com

# JWT secret for backend auth (Workers secret in production)
JWT_SECRET=change-me-in-production

# Resend email (password reset, store invites) — set as Workers secrets in production
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=noreply@yourdomain.com

# Cloudflare (CI/CD + wrangler CLI)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Legacy self-hosted production (Raspberry Pi + Docker) — deprecated
# PORT=3000

# Optional SQLite admin UI (task db-admin, dev only)
DB_ADMIN_USER=admin
DB_ADMIN_PASS=changeme

# Debug logging (dev: debug, prod: info/warn)
LOG_LEVEL=debug
NUXT_PUBLIC_LOG_LEVEL=debug
