# API base URL — must be reachable from the user's browser (NOT a Docker hostname)
# Local dev:  http://localhost:3001
# Production: leave empty — client uses window.location.origin + '/api' via Nginx
API_URL=http://localhost:3001
NUXT_PUBLIC_API_URL=http://localhost:3001

# Frontend base URL for invite links
# NUXT_PUBLIC_APP_URL=https://pos.zkcnt.com
# APP_URL=https://pos.zkcnt.com

# JWT secret for backend auth (change in production)
JWT_SECRET=change-me-in-production

# Production Nginx host port (Cloudflare tunnel should point here)
PORT=3000

# Optional SQLite admin UI (task db-admin, dev only)
DB_ADMIN_USER=admin
DB_ADMIN_PASS=changeme
